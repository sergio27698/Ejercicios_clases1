Algoritmo destribucion_de_utilidades
	Escribir "Ingrese el monto de utilidades"
	leer utilidades
	socioA<-utilidades*0.45
	socioB<-utilidades*0.30
	reserva_operativa<-utilidades*0.25
	Escribir "Socio A: ",socioA
	Escribir "Socio B: ",socioB
	Escribir "Reserva operativa: ",reserva_operativa
FinAlgoritmo
